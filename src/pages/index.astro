---
import BaseLayout from '../layouts/BaseLayout.astro'
import { SITE, PACKAGES } from '../lib/config'

const singlePackages = PACKAGES.filter(p => !p.recurring)
const monthlyPackages = PACKAGES.filter(p => p.recurring)
---

<BaseLayout
  title={`${SITE.name} — Drive-In Car Wash in Greer, SC`}
  description="The Car Wash in Greer, SC — fast drive-in car wash with packages from $8. Basic, Classic, and Premium Shine. Unlimited monthly plans available."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-navy-900">
    <!-- Background gradient orbs -->
    <div class="pointer-events-none absolute -top-40 -right-40 h-96 w-96 rounded-full bg-sky-600/20 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-20 -left-20 h-80 w-80 rounded-full bg-sky-800/30 blur-3xl"></div>
    <!-- Subtle grid -->
    <div class="pointer-events-none absolute inset-0 opacity-5"
      style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 40px 40px;">
    </div>

    <div class="relative mx-auto max-w-6xl px-4 py-24 text-center sm:py-32">
      <div class="inline-flex items-center gap-2 rounded-full border border-sky-700/50 bg-sky-900/40 px-4 py-1.5 text-sm font-medium text-sky-300 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-sky-400"></span>
        Drive-In Car Wash · Greer, SC
      </div>

      <h1 class="text-5xl font-black tracking-tight text-white sm:text-6xl lg:text-7xl">
        Drive In.<br>
        <span class="text-sky-400">Drive Clean.</span>
      </h1>

      <p class="mx-auto mt-6 max-w-xl text-lg text-gray-300">
        15 years of experience. Five-minute washes. Packages starting at just&nbsp;<strong class="text-amber-400">$8</strong>.
        No appointment needed — just drive up.
      </p>

      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/store"
          class="rounded-xl bg-amber-400 px-8 py-3.5 text-base font-bold text-navy-900 shadow-lg shadow-amber-400/20 transition hover:bg-amber-300">
          See Our Packages
        </a>
        <a href="/contact"
          class="rounded-xl border border-white/20 bg-white/10 px-8 py-3.5 text-base font-semibold text-white backdrop-blur-sm transition hover:bg-white/20">
          Get Directions
        </a>
      </div>

      <!-- Trust strip -->
      <div class="mx-auto mt-16 grid max-w-2xl grid-cols-2 gap-6 sm:grid-cols-4">
        {[
          { value: '15+', label: 'Years Experience' },
          { value: '5 min', label: 'Average Wash Time' },
          { value: '$8', label: 'Packages Start At' },
          { value: 'Drive-In', label: 'No Appointment' },
        ].map(stat => (
          <div class="rounded-xl border border-white/10 bg-white/5 p-4">
            <div class="text-2xl font-black text-amber-400">{stat.value}</div>
            <div class="mt-1 text-xs text-gray-400">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Wave divider -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 48h1440V24C1200 0 960 48 720 48S240 0 0 24v24z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- Packages teaser -->
  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="text-center">
      <span class="text-sm font-semibold uppercase tracking-wider text-sky-600">Simple Pricing</span>
      <h2 class="mt-2 text-3xl font-black text-gray-900 sm:text-4xl">Pick Your Wash</h2>
      <p class="mt-3 text-gray-500">Three options. No hidden fees. Done in minutes.</p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {singlePackages.map(pkg => (
        <div class={`relative flex flex-col rounded-2xl border p-6 shadow-sm transition hover:shadow-md ${
          pkg.popular
            ? 'border-sky-200 bg-gradient-to-b from-sky-50 to-white ring-2 ring-sky-500'
            : 'border-gray-200 bg-white'
        }`}>
          {pkg.popular && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="rounded-full bg-sky-600 px-3 py-1 text-xs font-bold text-white shadow">
                Most Popular
              </span>
            </div>
          )}
          <div class="flex items-start justify-between">
            <div>
              <h3 class="text-lg font-bold text-gray-900">{pkg.name}</h3>
              <p class="mt-1 text-sm text-gray-500">{pkg.description}</p>
            </div>
            <div class="ml-4 shrink-0 text-right">
              <span class="text-3xl font-black text-navy-900">{pkg.priceDisplay}</span>
            </div>
          </div>
          <ul class="mt-4 space-y-2 flex-1">
            {pkg.features.map(f => (
              <li class="flex items-center gap-2 text-sm text-gray-600">
                <svg class="h-4 w-4 shrink-0 text-sky-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href={`/store#${pkg.id}`}
            class={`mt-6 block rounded-xl py-2.5 text-center text-sm font-semibold transition ${
              pkg.popular
                ? 'bg-sky-600 text-white hover:bg-sky-700'
                : 'border border-gray-200 bg-white text-gray-700 hover:border-sky-200 hover:bg-sky-50 hover:text-sky-700'
            }`}>
            Get This Wash
          </a>
        </div>
      ))}
    </div>

    <p class="mt-8 text-center text-sm text-gray-500">
      Wash every week? Check out our{' '}
      <a href="/store#monthly" class="font-semibold text-sky-600 underline-offset-2 hover:underline">
        Unlimited Monthly Plans
      </a>
      {' '}starting at $35/mo.
    </p>
  </section>

  <!-- How It Works -->
  <section class="bg-foam-50 px-4 py-20">
    <div class="mx-auto max-w-4xl">
      <div class="text-center">
        <span class="text-sm font-semibold uppercase tracking-wider text-sky-600">The Process</span>
        <h2 class="mt-2 text-3xl font-black text-gray-900 sm:text-4xl">Three Easy Steps</h2>
      </div>

      <div class="mt-12 grid gap-8 sm:grid-cols-3">
        {[
          {
            step: '01',
            title: 'Drive In',
            body: 'Pull straight into our drive-in lane. No appointment, no waiting on hold — just show up.',
            icon: '🚗',
          },
          {
            step: '02',
            title: 'Choose Your Package',
            body: 'Pick Basic, Classic, or Premium Shine at the kiosk. Pay by card or your monthly pass.',
            icon: '✅',
          },
          {
            step: '03',
            title: 'Drive Out Spotless',
            body: 'Done in under five minutes. Your car comes out clean, dry, and ready to roll.',
            icon: '✨',
          },
        ].map(item => (
          <div class="relative rounded-2xl bg-white p-6 shadow-sm">
            <div class="text-4xl">{item.icon}</div>
            <div class="mt-4 text-xs font-bold uppercase tracking-widest text-sky-500">{item.step}</div>
            <h3 class="mt-1 text-lg font-bold text-gray-900">{item.title}</h3>
            <p class="mt-2 text-sm text-gray-500 leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">
      <div>
        <span class="text-sm font-semibold uppercase tracking-wider text-sky-600">Why The Car Wash</span>
        <h2 class="mt-2 text-3xl font-black text-gray-900 sm:text-4xl">Built for People in a Hurry</h2>
        <p class="mt-4 text-gray-500 leading-relaxed">
          We know you don't have an hour to spare. Our drive-in lane is designed for
          speed without sacrificing quality. 15 years of running washes means we've
          figured out exactly how to get your car clean fast.
        </p>

        <div class="mt-8 grid grid-cols-2 gap-4">
          {[
            { title: 'Speed', body: 'Average wash time under 5 minutes' },
            { title: 'Value', body: 'Quality washes from just $8' },
            { title: 'Expertise', body: '15 years in the car wash business' },
            { title: 'Convenience', body: 'Drive in any time, no booking needed' },
          ].map(item => (
            <div class="rounded-xl border border-gray-100 bg-gray-50 p-4">
              <h4 class="font-bold text-gray-900">{item.title}</h4>
              <p class="mt-1 text-xs text-gray-500">{item.body}</p>
            </div>
          ))}
        </div>

        <a href="/services"
          class="mt-8 inline-flex items-center gap-2 rounded-xl bg-sky-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-sky-700">
          See All Services
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <!-- Visual block -->
      <div class="mt-12 lg:mt-0">
        <div class="relative rounded-3xl bg-gradient-to-br from-sky-600 to-navy-800 p-8 text-white overflow-hidden">
          <div class="pointer-events-none absolute -top-10 -right-10 h-40 w-40 rounded-full bg-sky-500/20 blur-2xl"></div>
          <div class="pointer-events-none absolute -bottom-10 -left-10 h-40 w-40 rounded-full bg-amber-400/10 blur-2xl"></div>
          <blockquote class="relative">
            <svg class="h-8 w-8 text-sky-300/40" fill="currentColor" viewBox="0 0 32 32">
              <path d="M10 8c-3.3 0-6 2.7-6 6v10h10V14H8c0-1.1.9-2 2-2V8zm14 0c-3.3 0-6 2.7-6 6v10h10V14h-6c0-1.1.9-2 2-2V8z"/>
            </svg>
            <p class="mt-2 text-lg font-semibold leading-relaxed">
              "We understand the car wash business — 15 years in this business means
              we know exactly what keeps your car looking great and your time from being wasted."
            </p>
            <footer class="mt-6 flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-amber-400 text-navy-900 font-black text-sm">JM</div>
              <div>
                <div class="font-semibold">Joshua Mukui</div>
                <div class="text-sm text-sky-300">Owner, The Car Wash</div>
              </div>
            </footer>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Monthly Plans CTA -->
  <section class="bg-navy-900 px-4 py-20">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <span class="text-sm font-semibold uppercase tracking-wider text-amber-400">Save More Every Month</span>
        <h2 class="mt-2 text-3xl font-black text-white sm:text-4xl">Unlimited Monthly Plans</h2>
        <p class="mt-3 text-gray-400">Wash as often as you like. One flat monthly rate.</p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 max-w-3xl mx-auto">
        {monthlyPackages.map(pkg => (
          <div class={`rounded-2xl p-6 ${
            pkg.popular
              ? 'bg-gradient-to-b from-sky-600 to-sky-700 text-white ring-2 ring-amber-400'
              : 'border border-navy-700 bg-navy-800 text-gray-100'
          }`}>
            {pkg.popular && (
              <div class="mb-3">
                <span class="rounded-full bg-amber-400 px-3 py-1 text-xs font-bold text-navy-900">Best Value</span>
              </div>
            )}
            <h3 class="text-xl font-bold">{pkg.name}</h3>
            <div class="mt-2 flex items-end gap-1">
              <span class="text-4xl font-black">{pkg.priceDisplay}</span>
              <span class={`pb-1 text-sm ${pkg.popular ? 'text-sky-200' : 'text-gray-400'}`}>/mo</span>
            </div>
            <p class={`mt-2 text-sm ${pkg.popular ? 'text-sky-100' : 'text-gray-400'}`}>{pkg.description}</p>
            <ul class="mt-4 space-y-2">
              {pkg.features.map(f => (
                <li class="flex items-center gap-2 text-sm">
                  <svg class={`h-4 w-4 shrink-0 ${pkg.popular ? 'text-amber-300' : 'text-sky-400'}`} fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href={`/store#${pkg.id}`}
              class={`mt-6 block rounded-xl py-3 text-center text-sm font-bold transition ${
                pkg.popular
                  ? 'bg-amber-400 text-navy-900 hover:bg-amber-300'
                  : 'border border-sky-600 text-sky-400 hover:bg-sky-600 hover:text-white'
              }`}>
              Start Membership
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact CTA strip -->
  <section class="border-t border-gray-100 bg-foam-50 px-4 py-16">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-2xl font-black text-gray-900">Questions? We're Easy to Reach.</h2>
      <p class="mt-3 text-gray-500">Come see us, call, or shoot us a message.</p>
      <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
        <a href={`tel:${SITE.phone}`}
          class="flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-6 py-3 text-sm font-semibold text-gray-700 shadow-sm hover:border-sky-200 hover:text-sky-700 transition">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {SITE.phone}
        </a>
        <a href="/contact"
          class="rounded-xl bg-sky-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-sky-700 transition">
          Send a Message
        </a>
      </div>
      <p class="mt-4 text-xs text-gray-400">{SITE.hours}</p>
    </div>
  </section>
</BaseLayout>
