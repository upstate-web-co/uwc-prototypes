---
import BaseLayout from '../layouts/BaseLayout.astro'
import { SITE } from '../lib/config'
---

<BaseLayout
  title={`Contact — ${SITE.name}`}
  description="Contact The Car Wash in Greer, SC. Call, message, or just drive in — we're open Mon–Sat 7am–8pm, Sun 8am–6pm."
>
  <!-- Header -->
  <section class="bg-gradient-to-b from-navy-900 to-navy-800 px-4 py-16 text-center text-white">
    <div class="mx-auto max-w-3xl">
      <span class="text-sm font-semibold uppercase tracking-wider text-sky-400">Get in Touch</span>
      <h1 class="mt-2 text-4xl font-black sm:text-5xl">Contact Us</h1>
      <p class="mt-4 text-gray-300">
        Questions about our packages? Want to set up a fleet account?
        We're easy to reach — or just drive right in.
      </p>
    </div>
  </section>

  <div class="bg-navy-800">
    <svg viewBox="0 0 1440 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 32h1440V16C1200 0 960 32 720 32S240 0 0 16v16z" fill="white"/>
    </svg>
  </div>

  <!-- Contact grid -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-12 lg:grid-cols-2">

      <!-- Left: info -->
      <div>
        <h2 class="text-2xl font-black text-gray-900">Find Us</h2>

        <div class="mt-8 space-y-6">
          <!-- Address -->
          <div class="flex items-start gap-4">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-sky-100 text-sky-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Address</h3>
              <p class="text-gray-600">{SITE.address}</p>
              <a href="https://maps.google.com/?q=The+Car+Wash+Greer+SC" target="_blank" rel="noopener"
                class="mt-1 text-sm font-medium text-sky-600 hover:underline">
                Get Directions →
              </a>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-start gap-4">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-sky-100 text-sky-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Phone</h3>
              <a href={`tel:${SITE.phone}`} class="text-sky-600 hover:underline">{SITE.phone}</a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-sky-100 text-sky-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Email</h3>
              <a href={`mailto:${SITE.email}`} class="text-sky-600 hover:underline">{SITE.email}</a>
            </div>
          </div>

          <!-- Hours -->
          <div class="flex items-start gap-4">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-sky-100 text-sky-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Hours</h3>
              <div class="mt-1 space-y-1 text-sm text-gray-600">
                <div class="flex items-center justify-between gap-8">
                  <span>Monday – Saturday</span>
                  <span class="font-medium">7:00 AM – 8:00 PM</span>
                </div>
                <div class="flex items-center justify-between gap-8">
                  <span>Sunday</span>
                  <span class="font-medium">8:00 AM – 6:00 PM</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Map placeholder -->
        <div class="mt-8 overflow-hidden rounded-2xl border border-gray-200">
          <div class="flex aspect-video items-center justify-center bg-gradient-to-br from-sky-50 to-sky-100">
            <div class="text-center">
              <div class="text-4xl">📍</div>
              <p class="mt-2 text-sm font-medium text-sky-700">Map coming soon</p>
              <p class="text-xs text-gray-500 mt-1">Greer, SC</p>
              <a
                href="https://maps.google.com/?q=The+Car+Wash+Greer+SC"
                target="_blank"
                rel="noopener"
                class="mt-3 inline-block rounded-lg bg-sky-600 px-4 py-1.5 text-xs font-semibold text-white hover:bg-sky-700"
              >
                Open in Google Maps
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div>
        <h2 class="text-2xl font-black text-gray-900">Send a Message</h2>
        <p class="mt-2 text-sm text-gray-500">We'll get back to you within one business day.</p>

        <form id="contact-form" class="mt-8 space-y-5">
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700">Name <span class="text-red-400">*</span></label>
              <input
                type="text" id="name" name="name" required autocomplete="name"
                placeholder="Jane Smith"
                class="mt-1 block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm shadow-sm transition focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700">Email <span class="text-red-400">*</span></label>
              <input
                type="email" id="email" name="email" required autocomplete="email"
                placeholder="jane@example.com"
                class="mt-1 block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm shadow-sm transition focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200"
              />
            </div>
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700">Phone <span class="text-gray-400 font-normal">(optional)</span></label>
            <input
              type="tel" id="phone" name="phone" autocomplete="tel"
              placeholder="(864) 555-0100"
              class="mt-1 block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm shadow-sm transition focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200"
            />
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium text-gray-700">Subject</label>
            <select
              id="subject" name="subject"
              class="mt-1 block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm shadow-sm transition focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200"
            >
              <option value="">Select a topic...</option>
              <option>Question about packages</option>
              <option>Monthly membership</option>
              <option>Fleet account inquiry</option>
              <option>General question</option>
              <option>Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700">Message <span class="text-red-400">*</span></label>
            <textarea
              id="message" name="message" rows="5" required
              placeholder="How can we help?"
              class="mt-1 block w-full resize-none rounded-xl border border-gray-200 px-4 py-2.5 text-sm shadow-sm transition focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full rounded-xl bg-sky-600 px-6 py-3.5 text-sm font-bold text-white shadow-sm transition hover:bg-sky-700 disabled:opacity-60"
          >
            Send Message
          </button>

          <div id="form-status" class="hidden rounded-xl p-4 text-center text-sm"></div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement
  const status = document.getElementById('form-status') as HTMLElement

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement
    btn.disabled = true
    btn.textContent = 'Sending...'
    status.classList.add('hidden')

    try {
      const data = Object.fromEntries(new FormData(form))
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      })

      if (res.ok) {
        status.textContent = "Message sent! We'll get back to you within one business day."
        status.className = 'rounded-xl bg-green-50 p-4 text-center text-sm text-green-700 border border-green-200'
        form.reset()
      } else {
        const err = await res.json() as { error?: string }
        status.textContent = err.error ?? 'Something went wrong. Please try again.'
        status.className = 'rounded-xl bg-red-50 p-4 text-center text-sm text-red-700 border border-red-200'
      }
    } catch {
      status.textContent = 'Network error. Please try again.'
      status.className = 'rounded-xl bg-red-50 p-4 text-center text-sm text-red-700 border border-red-200'
    } finally {
      btn.disabled = false
      btn.textContent = 'Send Message'
      status.classList.remove('hidden')
    }
  })
</script>
