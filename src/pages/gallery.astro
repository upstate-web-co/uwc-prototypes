---
import BaseLayout from '../layouts/BaseLayout.astro'
import { SITE } from '../lib/config'

const galleryItems = [
  {
    title: 'Premium Shine Result',
    caption: 'Deep-gloss finish after our Premium Shine package — every panel, every time.',
    gradient: 'from-sky-600 to-sky-800',
    icon: '✨',
    tag: 'Premium Shine',
    size: 'tall',
  },
  {
    title: 'Drive-In Lane',
    caption: 'Our wide, easy-to-navigate drive-in lane — pull right in.',
    gradient: 'from-navy-800 to-navy-900',
    icon: '🚗',
    tag: 'Facility',
    size: 'normal',
  },
  {
    title: 'Foam Pre-Soak',
    caption: 'Thick foam blanket lifts dirt before the brushes even touch your car.',
    gradient: 'from-blue-300 to-sky-500',
    icon: '🫧',
    tag: 'Process',
    size: 'normal',
  },
  {
    title: 'Wheel & Tire Detail',
    caption: 'Rim scrub and tire shine on every Classic and Premium wash.',
    gradient: 'from-gray-700 to-gray-900',
    icon: '🔵',
    tag: 'Classic Clean',
    size: 'tall',
  },
  {
    title: 'Spotless Windows',
    caption: 'Interior window clean included in Premium Shine.',
    gradient: 'from-sky-400 to-blue-600',
    icon: '🪟',
    tag: 'Premium Shine',
    size: 'normal',
  },
  {
    title: 'Quick & Easy Kiosk',
    caption: 'Pay in seconds — card, tap, or monthly pass.',
    gradient: 'from-amber-400 to-amber-600',
    icon: '💳',
    tag: 'Facility',
    size: 'normal',
  },
  {
    title: 'Interior Vacuum',
    caption: 'Full interior vacuum on our Premium Shine package.',
    gradient: 'from-sky-700 to-navy-800',
    icon: '🧹',
    tag: 'Premium Shine',
    size: 'normal',
  },
  {
    title: 'High-Pressure Rinse',
    caption: 'Powerful spray that blasts dirt off every surface.',
    gradient: 'from-sky-500 to-sky-700',
    icon: '💦',
    tag: 'Process',
    size: 'tall',
  },
  {
    title: 'Fresh Air Freshener',
    caption: 'Choose from 6 scents — included with Premium Shine.',
    gradient: 'from-green-500 to-teal-600',
    icon: '🌿',
    tag: 'Add-On',
    size: 'normal',
  },
]

const tags = ['All', 'Facility', 'Process', 'Premium Shine', 'Classic Clean', 'Add-On']

const stats = [
  { value: '100+', label: 'Google Reviews' },
  { value: '4.9★', label: 'Average Rating' },
  { value: '5 min', label: 'Avg. Wash Time' },
  { value: '7 days', label: 'Open Every Week' },
]
---

<BaseLayout
  title={`Gallery — ${SITE.name}`}
  description="See The Car Wash in action — drive-in lane, foam pre-soaks, premium shine results, and more from our Greer, SC car wash."
>
  <!-- Header -->
  <section class="relative overflow-hidden bg-gradient-to-b from-navy-900 to-navy-800 px-4 py-20 text-center text-white">
    <!-- Bubble decoration -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      {[
        { left: '10%', size: 'h-3 w-3', delay: 'delay-300', dur: '[animation-duration:5s]' },
        { left: '30%', size: 'h-2 w-2', delay: 'delay-700', dur: '[animation-duration:4s]' },
        { left: '55%', size: 'h-4 w-4', delay: 'delay-100', dur: '[animation-duration:6s]' },
        { left: '75%', size: 'h-2 w-2', delay: 'delay-500', dur: '[animation-duration:5s]' },
        { left: '90%', size: 'h-3 w-3', delay: 'delay-900', dur: '[animation-duration:4.5s]' },
      ].map(b => (
        <div
          class={`animate-bubble absolute bottom-0 ${b.size} rounded-full border border-sky-400/30 bg-sky-400/15 ${b.delay} ${b.dur}`}
          style={`left: ${b.left}`}
        ></div>
      ))}
    </div>
    <div class="relative mx-auto max-w-3xl">
      <span class="text-sm font-semibold uppercase tracking-wider text-sky-400">See the Results</span>
      <h1 class="mt-2 text-4xl font-black sm:text-5xl">Gallery</h1>
      <p class="mt-4 text-gray-300 max-w-xl mx-auto">
        A look inside The Car Wash — our facility, process, and the results we deliver every single day.
      </p>
    </div>
  </section>

  <div class="bg-navy-800">
    <svg viewBox="0 0 1440 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 32h1440V16C1200 0 960 32 720 32S240 0 0 16v16z" fill="white"/>
    </svg>
  </div>

  <!-- Stats strip -->
  <div class="border-b border-gray-100 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-6">
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-2xl font-black text-sky-600">{s.value}</div>
            <div class="text-xs text-gray-500">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Photos coming soon notice -->
  <div class="mx-auto max-w-6xl px-4 pt-8">
    <div class="flex items-center gap-3 rounded-xl border border-amber-200 bg-amber-50 px-5 py-4 text-sm text-amber-800">
      <svg class="h-5 w-5 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <span>
        <strong>Photos coming soon!</strong> This page is ready for real photos of your facility.
        Share images and we'll swap these placeholders right in.
      </span>
    </div>
  </div>

  <!-- Filter tags -->
  <section class="mx-auto max-w-6xl px-4 pt-6 pb-4">
    <div class="flex flex-wrap gap-2" id="filter-btns">
      {tags.map(tag => (
        <button
          data-tag={tag}
          class={`filter-btn rounded-full px-4 py-1.5 text-sm font-medium transition ${
            tag === 'All'
              ? 'bg-sky-600 text-white shadow-sm'
              : 'border border-gray-200 bg-white text-gray-600 hover:border-sky-300 hover:text-sky-700'
          }`}
        >
          {tag}
        </button>
      ))}
    </div>
  </section>

  <!-- Gallery grid (masonry-style via CSS grid rows) -->
  <section class="mx-auto max-w-6xl px-4 pb-20">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" id="gallery-grid">
      {galleryItems.map(item => (
        <div
          data-tag={item.tag}
          class={`gallery-card group relative overflow-hidden rounded-2xl shadow-sm transition hover:shadow-xl hover:-translate-y-1 ${item.size === 'tall' ? 'sm:row-span-2' : ''}`}
          style="transition: box-shadow 0.2s, transform 0.2s"
        >
          <!-- Placeholder image -->
          <div class={`flex items-center justify-center bg-gradient-to-br ${item.gradient} ${item.size === 'tall' ? 'aspect-[3/4] sm:h-full' : 'aspect-[4/3]'}`}>
            <div class="text-center px-4">
              <div class={`${item.size === 'tall' ? 'text-8xl' : 'text-6xl'} animate-float`}>{item.icon}</div>
              <div class="mt-3 text-sm font-bold text-white/90">{item.title}</div>
              <div class="mt-1 text-xs text-white/60 max-w-[160px] mx-auto leading-relaxed">{item.caption}</div>
            </div>
          </div>

          <!-- Overlay on hover -->
          <div class="absolute inset-0 flex flex-col justify-between bg-gradient-to-t from-black/70 via-black/10 to-transparent p-4 opacity-0 transition-opacity duration-200 group-hover:opacity-100">
            <div class="self-start">
              <span class="rounded-full bg-sky-500/90 px-2 py-0.5 text-xs font-semibold text-white">
                {item.tag}
              </span>
            </div>
            <div>
              <p class="text-sm font-semibold text-white">{item.title}</p>
              <p class="mt-0.5 text-xs text-gray-300">{item.caption}</p>
            </div>
          </div>

          <!-- Always-visible tag -->
          <div class="absolute left-3 top-3 group-hover:opacity-0 transition-opacity">
            <span class="rounded-full bg-black/40 px-2 py-0.5 text-xs font-medium text-white backdrop-blur-sm">
              {item.tag}
            </span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-gray-100 bg-foam-50 px-4 py-16 text-center">
    <div class="mx-auto max-w-xl">
      <h2 class="text-2xl font-black text-gray-900">Ready for Your Car to Look Like This?</h2>
      <p class="mt-3 text-gray-500">Drive in any time — no appointment, no wait. We're open 7 days.</p>
      <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
        <a href="/store"
          class="rounded-xl bg-sky-600 px-8 py-3.5 font-bold text-white shadow-sm hover:bg-sky-700 transition">
          See Packages & Pricing
        </a>
        <a href="/contact"
          class="rounded-xl border border-gray-200 bg-white px-8 py-3.5 font-semibold text-gray-700 shadow-sm hover:border-sky-200 hover:text-sky-700 transition">
          Get Directions
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn')
  const cards = document.querySelectorAll<HTMLElement>('.gallery-card')

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? 'All'

      filterBtns.forEach(b => {
        b.classList.remove('bg-sky-600', 'text-white', 'shadow-sm')
        b.classList.add('border', 'border-gray-200', 'bg-white', 'text-gray-600')
      })
      btn.classList.add('bg-sky-600', 'text-white', 'shadow-sm')
      btn.classList.remove('border', 'border-gray-200', 'bg-white', 'text-gray-600')

      cards.forEach(card => {
        if (tag === 'All' || card.dataset.tag === tag) {
          card.style.display = ''
        } else {
          card.style.display = 'none'
        }
      })
    })
  })
</script>
