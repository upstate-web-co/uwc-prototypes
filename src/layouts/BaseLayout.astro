---
import '../styles/global.css'
import SEOHead from '../components/SEOHead.astro'
import { SITE } from '../lib/config'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  schema?: Record<string, unknown>
}

const { title, description, ogImage, schema } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEOHead title={title} description={description} ogImage={ogImage} schema={schema} />
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased">
    <!-- Navigation -->
    <header class="border-b border-gray-200 bg-white">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
        <a href="/" class="text-xl font-bold text-gray-900">
          {SITE.name}
        </a>
        <div class="flex items-center gap-6">
          <!-- Add nav links per client -->
          <a href="/#services" class="text-sm text-gray-600 hover:text-gray-900">Services</a>
          <a href="/#about" class="text-sm text-gray-600 hover:text-gray-900">About</a>
          <a href="/#contact" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
            Contact
          </a>
        </div>
      </nav>
    </header>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 bg-gray-50">
      <div class="mx-auto max-w-6xl px-4 py-8">
        <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
          <p class="text-sm text-gray-500">
            &copy; {new Date().getFullYear()} {SITE.name}. All rights reserved.
          </p>
          <div class="flex gap-4 text-sm text-gray-500">
            {SITE.phone && <span>{SITE.phone}</span>}
            <a href={`mailto:${SITE.email}`} class="hover:text-gray-700">{SITE.email}</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
