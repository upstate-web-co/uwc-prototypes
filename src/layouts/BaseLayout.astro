---
import '../styles/global.css'
import SEOHead from '../components/SEOHead.astro'
import { SITE } from '../lib/config'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  schema?: Record<string, unknown>
}

const { title, description, ogImage, schema } = Astro.props
const currentPath = Astro.url.pathname

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/contact', label: 'Contact' },
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEOHead title={title} description={description} ogImage={ogImage} schema={schema} />
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased">

    <!-- Navigation -->
    <header class="sticky top-0 z-50 border-b border-sky-100 bg-white/95 backdrop-blur-sm shadow-sm">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 text-xl font-black text-navy-900">
          <span class="flex h-9 w-9 items-center justify-center rounded-full bg-sky-600 text-white text-sm font-black">TW</span>
          <span class="hidden sm:block">The Car Wash</span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden items-center gap-1 md:flex">
          {navLinks.map(link => (
            <a
              href={link.href}
              class={`rounded-lg px-3 py-2 text-sm font-medium transition-colors ${
                currentPath === link.href
                  ? 'bg-sky-50 text-sky-700'
                  : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'
              }`}
            >
              {link.label}
            </a>
          ))}
        </div>

        <!-- CTA + mobile button -->
        <div class="flex items-center gap-3">
          <a
            href="/store"
            class={`rounded-lg px-4 py-2 text-sm font-semibold transition-colors ${
              currentPath === '/store'
                ? 'bg-amber-500 text-white'
                : 'bg-amber-400 text-navy-900 hover:bg-amber-500'
            }`}
          >
            Buy a Package
          </a>
          <button
            id="menu-btn"
            aria-label="Toggle menu"
            class="flex items-center justify-center rounded-lg p-2 text-gray-600 hover:bg-gray-100 md:hidden"
          >
            <svg id="icon-menu" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg id="icon-close" class="hidden h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </nav>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden border-t border-gray-100 bg-white px-4 pb-4 md:hidden">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`block rounded-lg px-3 py-2.5 text-sm font-medium ${
              currentPath === link.href
                ? 'bg-sky-50 text-sky-700'
                : 'text-gray-600 hover:bg-gray-50'
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-navy-900 text-gray-300">
      <div class="mx-auto max-w-6xl px-4 py-12">
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          <!-- Brand -->
          <div class="lg:col-span-2">
            <div class="flex items-center gap-2 text-xl font-black text-white">
              <span class="flex h-9 w-9 items-center justify-center rounded-full bg-sky-600 text-sm font-black">TW</span>
              The Car Wash
            </div>
            <p class="mt-3 text-sm text-gray-400 max-w-xs">
              Drive-in car wash serving Greer, SC with 15 years of experience.
              Fast, reliable, and spotless every time.
            </p>
            <div class="mt-4 flex gap-3">
              <a href={SITE.facebook} target="_blank" rel="noopener" aria-label="Facebook"
                class="flex h-9 w-9 items-center justify-center rounded-full bg-navy-800 text-gray-400 hover:bg-sky-600 hover:text-white transition-colors">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
              </a>
              <a href={SITE.instagram} target="_blank" rel="noopener" aria-label="Instagram"
                class="flex h-9 w-9 items-center justify-center rounded-full bg-navy-800 text-gray-400 hover:bg-sky-600 hover:text-white transition-colors">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Quick links -->
          <div>
            <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-400">Quick Links</h4>
            <ul class="mt-3 space-y-2">
              {navLinks.map(link => (
                <li>
                  <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">
                    {link.label}
                  </a>
                </li>
              ))}
              <li>
                <a href="/store" class="text-sm text-amber-400 hover:text-amber-300 transition-colors font-medium">
                  Buy a Package →
                </a>
              </li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-400">Find Us</h4>
            <ul class="mt-3 space-y-2 text-sm text-gray-400">
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-sky-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                {SITE.address}
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4 shrink-0 text-sky-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                <a href={`tel:${SITE.phone}`} class="hover:text-white transition-colors">{SITE.phone}</a>
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-sky-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span>{SITE.hours}</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-navy-800 pt-6 sm:flex-row">
          <p class="text-xs text-gray-500">
            &copy; {new Date().getFullYear()} The Car Wash. All rights reserved.
          </p>
          <p class="text-xs text-gray-600">Greer, SC · Est. 2010</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('menu-btn')
      const menu = document.getElementById('mobile-menu')
      const iconMenu = document.getElementById('icon-menu')
      const iconClose = document.getElementById('icon-close')

      btn?.addEventListener('click', () => {
        const isHidden = menu?.classList.contains('hidden')
        menu?.classList.toggle('hidden', !isHidden)
        iconMenu?.classList.toggle('hidden', !isHidden)
        iconClose?.classList.toggle('hidden', isHidden)
      })
    </script>
  </body>
</html>
