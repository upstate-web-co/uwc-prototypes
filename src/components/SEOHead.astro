---
/**
 * SEOHead — include on every page for proper meta tags and JSON-LD.
 * Props override defaults from config.ts.
 */
import { SITE } from '../lib/config'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  canonicalUrl?: string
  schema?: Record<string, unknown>
}

const {
  title = SITE.name,
  description = SITE.tagline,
  ogImage,
  canonicalUrl,
  schema,
} = Astro.props

const pageTitle = title === SITE.name ? title : `${title} | ${SITE.name}`
const canonical = canonicalUrl || Astro.url.href

// Default LocalBusiness schema — update per client
const defaultSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: SITE.name,
  url: SITE.url,
  email: SITE.email,
  ...(SITE.phone ? { telephone: SITE.phone } : {}),
}

const schemaJson = schema || defaultSchema
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

{!SITE.indexable && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content={SITE.name} />
{ogImage && <meta property="og:image" content={ogImage} />}

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(schemaJson)} />
